# ─── Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=change_me_to_a_long_random_string

# ─── Database (provided automatically by Replit) ─────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─── Frontend (CORS) ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5000

# ─── External APIs (all optional — features degrade gracefully if absent) ─
OPENAI_API_KEY=sk-...
PINTEREST_ACCESS_TOKEN=...
YOUTUBE_API_KEY=...
BUFFER_ACCESS_TOKEN=...
GUMROAD_ACCESS_TOKEN=...
BITLY_ACCESS_TOKEN=...
